		"test:e2e": "bun run build && playwright test"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.2.0",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-slider": "^1.3.6",
		"@types/file-saver": "^2.0.7",
		"@types/mdx": "^2.0.13",
		"file-saver": "^2.0.5",
		"jotai": "^2.18.1",
		"jszip": "^3.10.1",
		"next": "16.2.0",
		"react": "^19.2.4",
		"react-colorful": "^5.6.1",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4.2.2",
