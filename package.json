	"prettier": {
		"trailingComma": "es5",
		"tabWidth": 2,
		"useTabs": true,
		"semi": true,
		"singleQuote": false,
		"proseWrap": "preserve",
		"quoteProps": "as-needed",
		"arrowParens": "always",
		"bracketSpacing": true,
		"endOfLine": "lf",
		"htmlWhitespaceSensitivity": "css",
		"insertPragma": false,
		"singleAttributePerLine": false,
		"bracketSameLine": false,
		"jsxSingleQuote": false,
		"printWidth": 80,
		"plugins": [
			"prettier-plugin-tailwindcss"
		]
